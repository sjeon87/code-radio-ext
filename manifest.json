{
  "manifest_version": 3,
  "name": "Code Radio Player",
  "version": "1.0.0",
  "description": "Play freeCodeCamp Code Radio in your browser with volume control, bitrate selection, and background playback.",
  "permissions": ["offscreen", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Code Radio Player",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
